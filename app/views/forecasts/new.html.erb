<main>
  <h1>Forecast Lookup</h1>

  <% if @error_message.present? %>
    <p style="color: #b42318;"><%= @error_message %></p>
  <% end %>

  <%= form_with url: forecast_path, method: :get, local: true do |form| %>
    <div>
      <%= form.label :address, "Address" %><br>
      <%= form.text_field :address, value: @address, required: true, placeholder: "123 Main St, Miami, FL" %>
    </div>

    <div style="margin-top: 12px;">
      <%= form.submit "Get Forecast" %>
    </div>
  <% end %>
</main>
