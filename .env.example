# App
RAILS_ENV=development
PORT=3000
RAILS_MAX_THREADS=5

# Forecast integration (fill when API is wired)
FORECAST_API_BASE_URL=
FORECAST_API_KEY=

# Weather
WEATHER_API_BASE_URL=https://api.open-meteo.com
WEATHER_USER_AGENT=avenue-code-forecast/1.0
WEATHER_OPEN_TIMEOUT=5
WEATHER_READ_TIMEOUT=5

# Geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=avenue-code-forecast/1.0
GEOCODER_OPEN_TIMEOUT=5
GEOCODER_READ_TIMEOUT=5
